# Release-signing config template for the Speedrun Android app.
#
# Copy this file to `keystore.properties` (which is gitignored) and fill in the
# real values. The keystore itself is stored OUTSIDE the repository so no
# private key or password is ever committed.
#
#   cp keystore.properties.example keystore.properties
#   # then edit the paths/passwords below
#
# Generate the keystore once and keep it backed up somewhere safe (losing it
# means you can never ship an update signed with the same key):
#
#   keytool -genkeypair -v \
#     -keystore "$HOME/.speedrun-release/speedrun-release.jks" \
#     -alias speedrun -keyalg RSA -keysize 2048 -validity 10000
#
# Build the signed release APK:
#
#   ./gradlew :app:assembleRelease
#   # output: app/build/outputs/apk/release/app-release.apk (v2-signed)

storeFile=/absolute/path/to/speedrun-release.jks
storePassword=CHANGE_ME
keyAlias=speedrun
keyPassword=CHANGE_ME
